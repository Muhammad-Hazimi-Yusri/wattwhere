---
import '../styles/global.css';
import StoryMap from '../components/story/StoryMap.tsx';
import ScrollyController from '../components/story/ScrollyController.tsx';
import StoryProgress from '../components/story/StoryProgress.tsx';
import StepProgress from '../components/story/StepProgress.tsx';
import BillFlowCards from '../components/charts/BillFlowCards.tsx';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Common Tailwind class strings for each section + card. Kept here so
// individual sections only differ in `data-step`, accent, and copy —
// the layout shape stays a single source of truth.
const SECTION_BASE =
  'min-h-[100dvh] flex flex-col justify-end pb-8 md:block md:min-h-screen md:pb-0';
const SECTION_SHORT =
  'min-h-[80dvh] flex flex-col justify-end pb-8 md:block md:min-h-[60vh] md:pb-0';
const CARD =
  'space-y-3 md:space-y-4 rounded-lg bg-black/65 p-5 backdrop-blur md:bg-transparent md:p-0 md:backdrop-blur-0';
const EYEBROW =
  'text-[11px] font-semibold uppercase tracking-[0.18em]';
const HERO_L =
  'text-[4rem] leading-[1.05] md:text-[6.5rem] font-semibold tracking-tight tabular-nums';
const HERO_XL =
  'text-[5.5rem] leading-none md:text-[8.5rem] font-semibold tracking-tight tabular-nums';
const HERO_LABEL = 'text-xl md:text-3xl font-medium text-white';
const BODY = 'text-base md:text-lg text-white/80';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A scrolly explainer of the GB electricity grid and market."
    />
    <title>wattwhere</title>
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <main class="mx-auto max-w-7xl px-4 md:px-8">
      <header class="py-6 md:py-10 relative">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">
          wattwhere
        </h1>
        <p class="mt-2 text-sm md:text-base text-[color:var(--muted)]">
          A scrolly explainer of the GB electricity grid.
        </p>
      </header>

      <div class="md:grid md:grid-cols-2 md:gap-8 md:items-start">
        <!--
          Map sits behind everything on <md (fixed inset-0 -z-10) and
          inside the grid as a sticky right column on md+. Same component
          instance either way; ResizeObserver in StoryMap re-measures
          across the breakpoint.
        -->
        <aside
          class="fixed inset-0 -z-10 h-[100dvh] w-screen md:relative md:inset-auto md:sticky md:top-4 md:order-2 md:z-10 md:h-[calc(100vh-2rem)] md:w-auto"
        >
          <StoryMap client:only="react" />
        </aside>

        <article class="md:order-1 md:py-12 md:space-y-32 max-w-prose">
          <!--
            intro is SSR-baked with data-seen='true' so the first card
            doesn't flash opacity 0 on hydration. ScrollyController's IO
            still observes it; setting an already-true attribute is a
            no-op.
          -->
          <section
            data-step="intro"
            data-seen="true"
            style="--step-accent: #58a6ff"
            class={SECTION_BASE}
          >
            <div class={CARD}>
              <p class={EYEBROW} style="color: var(--step-accent)">
                01 · Britain's grid
              </p>
              <h2
                class={HERO_L}
                style="color: var(--step-accent)"
                aria-label="thirty gigawatts"
              >
                30&nbsp;GW
              </h2>
              <p class={HERO_LABEL}>Typical national demand</p>
              <p class={BODY}>
                One nationwide network moves power from where it's generated
                to where it's used.
              </p>
            </div>
          </section>

          <section
            data-step="regions"
            style="--step-accent: #fee08b"
            class={SECTION_BASE}
          >
            <div class={CARD}>
              <p class={EYEBROW} style="color: var(--step-accent)">
                02 · Distribution
              </p>
              <h2 class={HERO_XL} style="color: var(--step-accent)">14</h2>
              <p class={HERO_LABEL}>Distribution networks</p>
              <p class={BODY}>
                Below 132&nbsp;kV the grid splits into 14 DNO regions — the
                same shapes the National Grid scores for live carbon
                intensity.
              </p>
            </div>
          </section>

          <section
            data-step="plants"
            style="--step-accent: #1a9850"
            class={SECTION_BASE}
          >
            <div class={CARD}>
              <p class={EYEBROW} style="color: var(--step-accent)">
                03 · Generation
              </p>
              <h2 class={HERO_L} style="color: var(--step-accent)">70%</h2>
              <p class={HERO_LABEL}>Low-carbon today</p>
              <p class={BODY}>
                Wind dominates in the north and offshore; the remaining
                nuclear sits at Heysham, Hartlepool and Sizewell.
              </p>
            </div>
          </section>

          <section
            data-step="supergrid"
            style="--step-accent: #ef8a62"
            class={SECTION_BASE}
          >
            <div class={CARD}>
              <p class={EYEBROW} style="color: var(--step-accent)">
                04 · Transmission
              </p>
              <h2
                class={HERO_L}
                style="color: var(--step-accent)"
                aria-label="four hundred kilovolts"
              >
                400&nbsp;kV
              </h2>
              <p class={HERO_LABEL}>The super-grid</p>
              <p class={BODY}>
                Pylons carry generation south through the spine of England,
                then step down for the final mile.
              </p>
            </div>
          </section>

          <section
            data-step="closer-look"
            style="--step-accent: #67a9cf"
            class={SECTION_BASE}
          >
            <div class={CARD}>
              <p class={EYEBROW} style="color: var(--step-accent)">
                05 · Last mile
              </p>
              <h2 class={HERO_L} style="color: var(--step-accent)">
                Hundreds
              </h2>
              <p class={HERO_LABEL}>of London substations</p>
              <p class={BODY}>
                Each grey dot is a step-down transformer where high-voltage
                transmission meets the low-voltage street network.
              </p>
            </div>
          </section>

          <section
            data-step="bill"
            style="--step-accent: #fee08b"
            class={SECTION_SHORT}
          >
            <div class={CARD}>
              <p class={EYEBROW} style="color: var(--step-accent)">
                06 · Your bill
              </p>
              <h2 class={HERO_XL} style="color: var(--step-accent)">£1</h2>
              <p class={HERO_LABEL}>Where each pound goes</p>
              <p class={BODY}>
                Only part pays for the energy itself — the rest funds the
                network, government schemes, the supplier's costs, and VAT.
              </p>
              <BillFlowCards client:visible />
              <p class="mt-6">
                <a
                  href={`${base}explore`}
                  class="inline-block rounded-md border border-white/15 px-4 py-2 text-sm font-medium hover:bg-white/5"
                >
                  Open the live dashboard →
                </a>
              </p>
            </div>
          </section>
        </article>
      </div>
    </main>

    <ScrollyController client:only="react" />
    <StoryProgress client:only="react" />
    <StepProgress client:only="react" />
  </body>
</html>
